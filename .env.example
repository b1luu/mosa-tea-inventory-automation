SQUARE_ACCESS_TOKEN=your_square_access_token_here
SQUARE_ENVIRONMENT=sandbox
OPERATOR_API_TOKEN=replace_with_a_long_random_operator_token
SQUARE_OAUTH_CLIENT_ID=your_square_oauth_client_id_here
SQUARE_OAUTH_CLIENT_SECRET=your_square_oauth_client_secret_here
SQUARE_OAUTH_REDIRECT_URI=https://your-public-app.example.com/oauth/square/callback
SQUARE_OAUTH_SCOPES=MERCHANT_PROFILE_READ,ORDERS_READ,INVENTORY_READ,INVENTORY_WRITE,ITEMS_READ
SQUARE_WEBHOOK_SIGNATURE_KEY=your_square_webhook_signature_key_here
SQUARE_WEBHOOK_NOTIFICATION_URL=https://your-public-webhook-url.example.com/webhook/square
WEBHOOK_DISPATCH_MODE=local
ORDER_PROCESSING_STORE_MODE=sqlite
WEBHOOK_EVENT_STORE_MODE=sqlite
MERCHANT_STORE_MODE=sqlite
AWS_REGION=us-west-2
WEBHOOK_JOB_QUEUE_URL=https://sqs.us-west-2.amazonaws.com/123456789012/your-queue-name
DYNAMODB_ORDER_PROCESSING_TABLE=mosa-tea-order-processing
DYNAMODB_WEBHOOK_EVENT_TABLE=mosa-tea-webhook-events
DYNAMODB_MERCHANT_CONNECTION_TABLE=mosa-tea-merchant-connections
DYNAMODB_MERCHANT_CATALOG_BINDING_TABLE=mosa-tea-merchant-bindings
MERCHANT_SECRET_PREFIX=mosa-tea/merchant-auth
